<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
        Vendor aggregate root. Identity is generated by the aggregate
        (VendorId, UUID v7) via the IdentityGenerator port — no
        GeneratedValue strategy here. Stored as a 36-char string column
        via the inventory_vendor_id custom type.

        The vendor address is persisted as a single JSONB column via the
        inventory_vendor_address custom type rather than as an
        embeddable: ORM 3 has no "null embeddable vs empty embeddable"
        distinction, so optional address fields would have to be
        nullable on the embeddable and break the VO invariant that all
        fields are non-null when the address exists. JSONB is either
        NULL or a complete object the VO factory revalidates.

        The functional index on LOWER(name) backs searchByName(); see
        the migration for the schema.
    -->
    <entity name="App\Inventory\Domain\Vendor" table="inventory_vendors">

        <unique-constraints>
            <unique-constraint name="UNIQ_inventory_vendors_code" columns="code"/>
        </unique-constraints>

        <indexes>
            <index name="IDX_inventory_vendors_archived" columns="archived"/>
        </indexes>

        <id name="id" type="inventory_vendor_id"/>

        <field name="code"         column="code"         type="inventory_vendor_code"     nullable="false"/>
        <field name="name"         column="name"         type="inventory_vendor_name"     nullable="false"/>
        <field name="contact"      column="contact"      type="inventory_vendor_contact"  nullable="false"/>
        <field name="email"        column="email"        type="inventory_email_address"   nullable="true"/>
        <field name="phone"        column="phone"        type="inventory_phone_number"    nullable="true"/>
        <field name="address"      column="address"      type="inventory_vendor_address"  nullable="true"/>
        <field name="archived"     column="archived"     type="boolean"                   nullable="false">
            <options>
                <option name="default">false</option>
            </options>
        </field>
        <field name="registeredAt" column="registered_at" type="datetime_immutable"       nullable="false"/>
        <field name="updatedAt"    column="updated_at"    type="datetime_immutable"       nullable="false"/>

    </entity>

</doctrine-mapping>
