<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
        ItemGroup aggregate root. Identity is generated by the
        aggregate (ItemGroupId, UUID v7) via the IdentityGenerator
        port — no GeneratedValue strategy.

        ItemGroupMembership child rows are persisted via a one-to-many
        on the members collection with cascade-persist + orphan
        removal. Membership lists can grow large (a single "Beverages"
        group may carry hundreds of items), so the association is
        LAZY-loaded — most write paths only need the parent and call
        addItem/removeItem, which Doctrine resolves via the per-pair
        composite key without hydrating siblings.
    -->
    <entity name="App\Inventory\Domain\ItemGroup" table="inventory_item_groups">

        <unique-constraints>
            <unique-constraint name="UNIQ_inventory_item_groups_name" columns="name"/>
        </unique-constraints>

        <id name="id" type="inventory_item_group_id"/>

        <field name="name"           column="name"           type="inventory_item_group_name"   nullable="false"/>
        <field name="color"          column="color_hex"      type="inventory_pos_color"         nullable="false"/>
        <field name="facilityScope"  column="facility_scope" type="inventory_facility_scope"    nullable="false"/>
        <field name="archived"       column="archived"       type="boolean"                     nullable="false">
            <options>
                <option name="default">false</option>
            </options>
        </field>
        <field name="createdAt"      column="created_at"     type="datetime_immutable"          nullable="false"/>
        <field name="updatedAt"      column="updated_at"     type="datetime_immutable"          nullable="false"/>

        <one-to-many field="members" target-entity="App\Inventory\Domain\ItemGroupMembership" mapped-by="group" fetch="LAZY" orphan-removal="true">
            <cascade>
                <cascade-persist/>
            </cascade>
            <order-by>
                <order-by-field name="addedAt" direction="ASC"/>
            </order-by>
        </one-to-many>

    </entity>

</doctrine-mapping>
