<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
        PurchaseOrder aggregate root. Identity is generated by the
        aggregate (PurchaseOrderId, UUID v7) via the IdentityGenerator
        port — no GeneratedValue strategy here.

        Vendor and Facility references are stored as scalar VOs (vendor_id,
        facility_code). No Doctrine association across aggregates; the
        PO holds the Vendor id only — vendor lifecycle and PO lifecycle
        are decoupled.

        PurchaseOrderLine children are persisted via a one-to-many on the
        lines collection with cascade-persist + orphan-removal so removing
        a line from the in-memory collection deletes the row on flush.
        <order-by> on created_at ASC, id ASC keeps the hydrated
        collection in deterministic order across receives.
    -->
    <entity name="App\Inventory\Domain\PurchaseOrder" table="inventory_purchase_orders">

        <indexes>
            <index name="IDX_inventory_po_vendor_status" columns="vendor_id,status"/>
            <index name="IDX_inventory_po_facility_status" columns="facility_code,status"/>
            <index name="IDX_inventory_po_status_created" columns="status,created_at"/>
        </indexes>

        <id name="id" type="inventory_purchase_order_id"/>

        <field name="vendorId"          column="vendor_id"         type="inventory_vendor_id"        nullable="false"/>
        <field name="facilityCode"      column="facility_code"     type="inventory_facility_code"    nullable="false"/>
        <field name="status"            column="status"            type="string"                     nullable="false" length="32" enum-type="App\Inventory\Domain\PurchaseOrderStatus"/>
        <field name="sentAt"            column="sent_at"           type="datetime_immutable"         nullable="true"/>
        <field name="estimatedArrival"  column="estimated_arrival" type="datetime_immutable"         nullable="true"/>
        <field name="verifiedByUserId"  column="verified_by"       type="string"                     nullable="true" length="36"/>
        <field name="verifiedAt"        column="verified_at"       type="datetime_immutable"         nullable="true"/>
        <field name="createdAt"         column="created_at"        type="datetime_immutable"         nullable="false"/>
        <field name="updatedAt"         column="updated_at"        type="datetime_immutable"         nullable="false"/>

        <one-to-many field="lines" target-entity="App\Inventory\Domain\PurchaseOrderLine" mapped-by="purchaseOrder" orphan-removal="true">
            <cascade>
                <cascade-persist/>
            </cascade>
            <order-by>
                <order-by-field name="createdAt" direction="ASC"/>
                <order-by-field name="id" direction="ASC"/>
            </order-by>
        </one-to-many>

    </entity>

</doctrine-mapping>
