<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!--
        Household aggregate root. Identity is generated by the aggregate
        (HouseholdId, UUID v7) via the IdentityGenerator port — no
        GeneratedValue strategy here. Stored as a 36-char string column
        via the households_household_id custom type.

        Address is embedded as a value object inline on the households
        table (street/unit/city/state/postal_code/country columns). The
        LRA-36 alignment note called for a separate household_addresses
        1:1 table; we collapsed it into the households table for
        simplicity — Doctrine ORM 3 has no first-class secondary-table
        support for embeddables, and Address has no independent identity
        in the domain. See migration for the schema.

        Members are a bidirectional one-to-many with the inverse side
        (mapped-by="household") owning the household_id FK column on
        household_members. orphan-removal + cascade={persist, remove}
        keeps the child table strictly owned by the aggregate.
    -->
    <entity name="App\Households\Domain\Household" table="households">

        <id name="id" type="households_household_id"/>

        <field name="name"      type="households_household_name" nullable="false"/>
        <field name="createdAt" type="datetime_immutable"        nullable="false"/>

        <embedded name="address" class="App\Households\Domain\ValueObject\Address" use-column-prefix="false"/>

        <one-to-many field="members" target-entity="App\Households\Domain\HouseholdMember" mapped-by="household" orphan-removal="true" fetch="EAGER">
            <cascade>
                <cascade-persist/>
                <cascade-remove/>
            </cascade>
        </one-to-many>

    </entity>

</doctrine-mapping>
