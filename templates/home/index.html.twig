{% extends 'base.html.twig' %}

{% block title %}LiteRecAdmin{% endblock %}

{% block body %}
    <main class="flex min-h-screen items-center justify-center bg-slate-100 p-6">
        <div data-gsap="card" class="w-full max-w-md rounded-xl border border-slate-300 bg-white p-8 shadow-sm">
            <h1 class="text-2xl font-bold text-slate-800">LiteRecAdmin</h1>
            <p class="mt-2 text-slate-600">The LiteRec staff administration application. Setup in progress.</p>

            <div x-data="{ open: false }" class="mt-6">
                <button
                    type="button"
                    class="rounded-md bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
                    x-on:click="open = !open"
                    :aria-expanded="open"
                    aria-controls="details-content"
                >
                    Toggle details
                </button>
                <p id="details-content" x-show="open" x-cloak class="mt-3 text-sm text-slate-500">
                    Tailwind CSS, Alpine.js, HTMX and GSAP are wired up through Symfony AssetMapper.
                </p>
            </div>

            <div class="mt-6">
                <button
                    type="button"
                    class="text-sm font-medium text-slate-700 underline"
                    hx-get="{{ path('app_health') }}"
                    hx-target="#health-result"
                    hx-indicator="#health-loading"
                >
                    Check health (HTMX)
                </button>
                <span id="health-loading" class="htmx-indicator ml-2 text-xs text-slate-500" role="status" aria-live="polite">Loading…</span>
                <pre id="health-result" class="mt-2 text-xs text-slate-500" aria-live="polite"></pre>
            </div>
        </div>
    </main>
{% endblock %}
