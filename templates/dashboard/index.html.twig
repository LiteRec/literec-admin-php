{% extends 'app.html.twig' %}

{% block page_title %}Admin Dashboard{% endblock %}

{# Exercises the page_actions block of app.html.twig so its contract is real,
   not theoretical. The richer dashboard actions arrive in LRA-27. #}
{% block page_actions %}
    <a
        href="{{ path('app_dashboard') }}"
        class="rounded-md border border-litrec-edge bg-white px-3 py-1.5 text-sm font-semibold text-litrec-ink shadow-sm hover:bg-litrec-bg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-ink"
    >
        Refresh
    </a>
{% endblock %}

{% block page_body %}
    <div data-gsap="card" class="rounded-xl border-2 border-litrec-edge bg-white p-6 shadow-card">
        <p class="text-sm text-litrec-edge">
            The full administrator dashboard arrives in LRA-27. This card lives inside the new authenticated
            app shell so the layout — header, navigation, content, footer — can be reviewed end to end.
        </p>
    </div>
{% endblock %}
