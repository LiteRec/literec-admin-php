{% extends 'app.html.twig' %}

{% import 'components/_icon.html.twig' as ui %}

{% block page_title %}Admin Dashboard{% endblock %}

{% block page_subtitle %}Welcome back. Here's what's happening across your facilities today.{% endblock %}

{% block page_body %}
    {# KPI tiles — gradient cards rendered through the reusable _kpi_card component. #}
    <section aria-labelledby="kpi-heading" class="mb-6">
        <h2 id="kpi-heading" class="sr-only">Key performance indicators</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {% for kpi in dashboard.kpis %}
                {% include 'components/_kpi_card.html.twig' with {
                    icon: kpi.icon,
                    value: kpi.value,
                    label: kpi.label,
                    gradient: kpi.gradient,
                    delta: kpi.delta,
                } only %}
            {% endfor %}
        </div>
    </section>

    <div class="mb-5 grid grid-cols-1 gap-5 lg:grid-cols-2">
        {# Recent Activity — real transaction feed, shown as a status-dotted list. #}
        <section aria-labelledby="activity-heading" data-gsap="card" class="lr-card">
            <div class="lr-card-head">
                <span class="lr-card-title inline-flex items-center gap-2">
                    {{ ui.icon('bolt', 16, 1.6, 'text-litrec-secondary') }}
                    <span id="activity-heading">Recent Activity</span>
                </span>
                <a href="{{ path('reports_index') }}" class="lr-link text-xs font-semibold">View all</a>
            </div>
            {% set dot_colors = {
                'succeeded': 'var(--lr-success)',
                'pending':   'var(--lr-warning)',
                'failed':    'var(--lr-danger)',
                'refunded':  'var(--lr-info)',
            } %}
            <div class="lr-list">
                {% for tx in dashboard.recentTransactions %}
                    <div class="lr-list-row">
                        <span class="lr-dot" style="background: {{ dot_colors[tx.status.value] ?? 'var(--lr-text-muted)' }}"></span>
                        <div class="min-w-0 flex-1">
                            <div class="lr-row-strong truncate text-sm">{{ tx.userName }}</div>
                            <div class="lr-muted text-xs">{{ tx.method }}</div>
                        </div>
                        <div class="text-right">
                            <div class="lr-row-strong lr-num text-sm">{{ tx.amountFormatted }}</div>
                            <div class="lr-muted text-xs">{{ tx.at|date('g:i A') }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>

        {# Upcoming Events — presentation-only sample data (Scheduling context pending). #}
        <section aria-labelledby="events-heading" data-gsap="card" class="lr-card">
            <div class="lr-card-head">
                <span class="lr-card-title inline-flex items-center gap-2">
                    {{ ui.icon('calendar', 16, 1.6, 'text-litrec-secondary') }}
                    <span id="events-heading">Upcoming Events</span>
                </span>
                <a href="{{ path('facilities_index') }}" class="lr-link text-xs font-semibold">View calendar</a>
            </div>
            <div class="lr-list">
                {% for event in dashboard.upcomingEvents %}
                    <div class="lr-list-row">
                        <span class="lr-datechip"><span class="d lr-num">{{ event.day }}</span><span class="m">{{ event.month }}</span></span>
                        <div class="min-w-0 flex-1">
                            <div class="lr-row-strong truncate text-sm">{{ event.title }}</div>
                            <div class="lr-muted inline-flex items-center gap-1 text-xs">{{ ui.icon('pin', 11) }} {{ event.location }}</div>
                        </div>
                        <span class="lr-chip lr-num">{{ ui.icon('users', 12) }} {{ event.attendees }}</span>
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>

    <div class="grid grid-cols-1 gap-5 lg:grid-cols-3">
        {# Facility Status — presentation-only sample data (Facilities read model pending). #}
        <section aria-labelledby="facilities-heading" data-gsap="card" class="lr-card lg:col-span-2">
            <div class="lr-card-head">
                <span class="lr-card-title inline-flex items-center gap-2">
                    {{ ui.icon('tree', 16, 1.6, 'text-litrec-secondary') }}
                    <span id="facilities-heading">Facility Status</span>
                </span>
                <a href="{{ path('facilities_index') }}" class="lr-link text-xs font-semibold">All facilities</a>
            </div>
            <div class="lr-list">
                {% for facility in dashboard.facilityStatuses %}
                    <div class="lr-list-row">
                        <div class="flex-1">
                            <div class="lr-row-strong text-sm">{{ facility.name }}</div>
                            <div class="mt-1 inline-flex items-center gap-2">
                                {% include 'components/_badge.html.twig' with { label: facility.conditionLabel, variant: facility.badgeVariant, class: 'uppercase' } only %}
                                <span class="lr-muted text-xs"><span class="lr-num">{{ facility.visitorsToday }}</span> visitors today</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>

        {# Quick Actions — real nav routes as dashed tiles. #}
        <section aria-labelledby="quick-actions-heading" data-gsap="card" class="lr-card">
            <div class="lr-card-head">
                <span class="lr-card-title inline-flex items-center gap-2">
                    {{ ui.icon('bolt', 16, 1.6, 'text-litrec-secondary') }}
                    <span id="quick-actions-heading">Quick Actions</span>
                </span>
            </div>
            <div class="lr-card-body">
                <div class="grid grid-cols-2 gap-3">
                    {% for link in dashboard.quickLinks %}
                        <a href="{{ path(link.route) }}" class="lr-quick">
                            {{ ui.icon(link.icon, 20) }}
                            <span class="text-sm font-semibold">{{ link.label }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>
    </div>
{% endblock %}
