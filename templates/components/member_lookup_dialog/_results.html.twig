{# Results partial for the Member Lookup dialog (LRA-46).

   Rendered by `MemberLookupController::__invoke` and swapped into the
   dialog's `#member-lookup-results` slot by HTMX. Each row is a button —
   not a link — because the action is "select this member and emit a
   `member-selected` event", not "navigate to the member page". The four
   payload attributes (`data-member-id`, `data-household-id`,
   `data-full-name`, `data-code`) are read by the inline Alpine handler
   and forwarded as the CustomEvent `detail` shape that callers consume.

   Expects:
     - page:     PageOfMembers
     - criteria: SearchMembersCriteria (unused here but kept consistent
                 with the list-page partials so a future "no matches for
                 \"$criteria.lastName\"" message can be added without
                 changing the call site) #}
{% if page.totalItems == 0 %}
    <p
        data-testid="member-lookup-empty"
        class="rounded-md border border-dashed border-litrec-border bg-litrec-surface p-4 text-center text-sm text-litrec-text-muted"
    >
        No members match.
    </p>
{% else %}
    <div class="overflow-x-auto rounded-card border border-litrec-border bg-litrec-surface shadow-card">
        <table class="min-w-full divide-y divide-litrec-border text-sm">
            <thead class="bg-litrec-bg-muted text-left text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
                <tr>
                    <th scope="col" class="px-4 py-2">Code</th>
                    <th scope="col" class="px-4 py-2">Full name</th>
                    <th scope="col" class="px-4 py-2">DOB</th>
                    <th scope="col" class="px-4 py-2">Phone</th>
                    <th scope="col" class="px-4 py-2">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-litrec-border">
                {% for item in page.items %}
                    <tr>
                        <td colspan="5" class="p-0">
                            <button
                                type="button"
                                data-testid="member-lookup-row-{{ item.memberId }}"
                                data-member-id="{{ item.memberId }}"
                                data-household-id="{{ item.householdId }}"
                                data-full-name="{{ item.fullName }}"
                                data-code="{{ item.memberCode }}"
                                class="grid w-full grid-cols-5 items-center gap-0 px-0 py-0 text-left hover:bg-litrec-bg-muted focus:bg-litrec-bg-muted focus:outline-none"
                                @click="
                                    window.dispatchEvent(new CustomEvent('member-selected', {
                                        detail: {
                                            memberId: $event.currentTarget.dataset.memberId,
                                            householdId: $event.currentTarget.dataset.householdId,
                                            fullName: $event.currentTarget.dataset.fullName,
                                            code: $event.currentTarget.dataset.code,
                                        }
                                    }));
                                    dismiss();
                                "
                            >
                                <span class="whitespace-nowrap px-4 py-2 font-mono text-xs text-litrec-text">{{ item.memberCode }}</span>
                                <span class="px-4 py-2 text-litrec-text">{{ item.fullName }}</span>
                                <span class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                                    {% if item.dobIso %}{{ item.dobIso }}{% else %}—{% endif %}
                                </span>
                                <span class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                                    {% if item.phone %}{{ item.phone }}{% else %}—{% endif %}
                                </span>
                                <span class="whitespace-nowrap px-4 py-2">
                                    {% if item.isActive %}
                                        <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800">Active</span>
                                    {% else %}
                                        <span class="inline-flex items-center rounded-full bg-gray-200 px-2 py-0.5 text-xs font-semibold text-gray-700">Deactivated</span>
                                    {% endif %}
                                    {% if item.isPrimary %}
                                        <span class="ml-1 inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-800">Primary</span>
                                    {% endif %}
                                </span>
                            </button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if page.totalItems > page.pageSize %}
        <p class="mt-2 text-xs text-litrec-text-muted" data-testid="member-lookup-overflow">
            Showing {{ page.items|length }} of {{ page.totalItems }} matches — refine your filters to narrow the list.
        </p>
    {% endif %}
{% endif %}
