{# @param string status One of: succeeded, pending, failed, refunded.
   Matches App\Ui\Dashboard\TransactionStatus::value. #}
{% set status_classes = {
    'succeeded': 'bg-green-100 text-green-800',
    'pending':   'bg-yellow-100 text-yellow-800',
    'failed':    'bg-red-100 text-red-800',
    'refunded':  'bg-blue-100 text-blue-800',
} %}
<span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ status_classes[status] ?? 'bg-gray-100 text-gray-800' }}">
    {{ status|capitalize }}
</span>
