{# Transaction-status badge. Maps a TransactionStatus value onto the shared
   lr-badge variant so there is one badge implementation, not two.

   @param string status One of: succeeded, pending, failed, refunded.
   Matches App\Ui\Dashboard\TransactionStatus::value. #}
{% set status_variants = {
    'succeeded': 'success',
    'pending':   'warning',
    'failed':    'danger',
    'refunded':  'info',
} %}
{% include 'components/_badge.html.twig' with {
    label: status|capitalize,
    variant: status_variants[status]|default('neutral'),
} only %}
