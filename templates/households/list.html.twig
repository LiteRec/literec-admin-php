{% extends 'app.html.twig' %}

{% block page_title %}Users{% endblock %}

{% block page_actions %}
    {# Disabled until LRA-40 ships the dialog. Kept in the DOM (with its
       data-testid) so functional tests can assert its presence; the
       disabled attribute + aria-disabled prevent interaction without
       relying on JavaScript. #}
    <button
        type="button"
        id="js-new-household"
        data-testid="open-new-household"
        disabled
        aria-disabled="true"
        title="Coming soon — wired up in LRA-40."
        class="cursor-not-allowed rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary opacity-60 shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
    >
        New Household
    </button>
    {% if exportDuplicatesEnabled %}
        <button
            type="button"
            data-testid="export-duplicates"
            class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
        >
            Export Duplicates
        </button>
    {% endif %}
{% endblock %}

{% block page_body %}
    {% include 'households/list/_filters.html.twig' %}

    <div
        id="members-table"
        data-testid="members-table"
        class="mt-6 transition-opacity htmx-request:opacity-50"
        hx-indicator="this"
    >
        {% include 'households/list/_table.html.twig' %}
    </div>
{% endblock %}
