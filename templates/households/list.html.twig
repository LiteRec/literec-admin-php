{% extends 'app.html.twig' %}

{% block page_title %}Users{% endblock %}

{% block page_actions %}
    {# LRA-40: opens the Register Household HTMX dialog. The fragment is
       appended to <body> so it overlays the page; closing the modal removes
       its root node and focus returns to this button. #}
    <button
        type="button"
        id="js-new-household"
        data-testid="open-new-household"
        hx-get="{{ path('households_new_form') }}"
        hx-target="body"
        hx-swap="beforeend"
        aria-haspopup="dialog"
        class="rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
    >
        New Household
    </button>
    {% if exportDuplicatesEnabled %}
        <button
            type="button"
            data-testid="export-duplicates"
            class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
        >
            Export Duplicates
        </button>
    {% endif %}
{% endblock %}

{% block page_body %}
    {% include 'households/list/_filters.html.twig' %}

    {# Polite live region (LRA-153), mirroring the inventory list pattern:
       refreshed out-of-band by the table partial on every HTMX swap so the
       result count is announced without moving focus. This initial copy
       guarantees the region exists on first paint. #}
    <span
        id="members-result-summary"
        aria-live="polite"
        class="sr-only"
    >Showing {{ page.items|length }} of {{ page.totalItems }} {{ page.totalItems == 1 ? 'member' : 'members' }}</span>

    <div
        id="members-table"
        data-testid="members-table"
        class="mt-6 transition-opacity htmx-request:opacity-50"
        hx-indicator="this"
    >
        {% include 'households/list/_table.html.twig' %}
    </div>
{% endblock %}
