{# Filter form for the View Members list. HTMX submits any field change to
   the partial endpoint and swaps the result into #members-table; the form's
   submit button is sr-only so keyboard users keep a fallback if JS is off. #}
{% set q = app.request.query %}
<form
    hx-get="{{ path('households_members_table') }}"
    hx-target="#members-table"
    hx-swap="innerHTML"
    hx-push-url="true"
    hx-trigger="input changed delay:500ms, change"
    aria-label="Filter members"
    class="rounded-card border border-litrec-border bg-litrec-surface p-4 shadow-card"
>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div>
            <label for="filter-memberCode" class="block text-sm font-medium text-litrec-text">Member code</label>
            <input
                type="text"
                id="filter-memberCode"
                name="memberCode"
                value="{{ q.get('memberCode', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-lastName" class="block text-sm font-medium text-litrec-text">Last name</label>
            <input
                type="text"
                id="filter-lastName"
                name="lastName"
                value="{{ q.get('lastName', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-firstName" class="block text-sm font-medium text-litrec-text">First name</label>
            <input
                type="text"
                id="filter-firstName"
                name="firstName"
                value="{{ q.get('firstName', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-phone" class="block text-sm font-medium text-litrec-text">Phone</label>
            <input
                type="text"
                id="filter-phone"
                name="phone"
                value="{{ q.get('phone', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-email" class="block text-sm font-medium text-litrec-text">Email</label>
            <input
                type="email"
                id="filter-email"
                name="email"
                value="{{ q.get('email', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div class="flex flex-col justify-end gap-2">
            <label class="inline-flex items-center gap-2 text-sm text-litrec-text">
                <input
                    type="checkbox"
                    id="filter-primaryOnly"
                    name="primaryOnly"
                    value="1"
                    {% if q.get('primaryOnly') in ['1', 'true', 'on', 'yes', true] %}checked{% endif %}
                    class="rounded border-litrec-border text-litrec-primary focus:ring-litrec-primary"
                >
                Primary members only
            </label>
            <label class="inline-flex items-center gap-2 text-sm text-litrec-text">
                <input
                    type="checkbox"
                    id="filter-includeDeleted"
                    name="includeDeleted"
                    value="1"
                    {% if q.get('includeDeleted') in ['1', 'true', 'on', 'yes', true] %}checked{% endif %}
                    class="rounded border-litrec-border text-litrec-primary focus:ring-litrec-primary"
                >
                Include deactivated
            </label>
        </div>
    </div>

    {# Keyboard-accessible fallback; HTMX fires on change so this is hidden. #}
    <button type="submit" class="sr-only">Apply filters</button>
</form>
