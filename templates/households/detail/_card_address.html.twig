{# Address & Residency card (LRA-44). See _card_household.html.twig for the
   URL-hash collapse-state contract; this partial binds the `cards.address`
   key.

   The card hosts two independent sub-cards (Address and Residency), each
   with its own read/edit swap target so a failure or pending edit in one
   does not affect the other. The two sub-card bodies live under their own
   ids (`#address-sub-card-body`, `#residency-sub-card-body`) and the
   surrounding card chrome (collapse-state <details>/<summary>) stays put
   across all swaps.

   Expects:
     - detail: App\Households\Application\Query\Port\MemberDetail
#}
<div class="rounded-card border border-litrec-border bg-litrec-surface shadow-card">
    <details
        class="group"
        :open="cards.address"
        @toggle="cards.address = $event.target.open; syncHash()"
    >
        <summary
            class="flex cursor-pointer list-none items-center justify-between gap-2 px-5 py-3 text-sm font-semibold uppercase tracking-wide text-litrec-text-muted"
            :aria-expanded="cards.address.toString()"
        >
            <span>Address &amp; Residency</span>
            <span aria-hidden="true" class="text-xs transition-transform group-open:rotate-180">▾</span>
        </summary>
        {% include 'households/detail/_card_address_read.html.twig' with { detail: detail } only %}
    </details>
</div>
