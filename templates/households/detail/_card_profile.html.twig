{# Profile card (LRA-43). See _card_household.html.twig for the URL-hash
   collapse-state contract; this partial binds the `cards.profile` key.

   The card chrome (collapse-state <details>/<summary>) stays put across
   read/edit swaps. The swappable body lives in #card-profile-body — both
   _card_profile_read.html.twig and _card_profile_edit.html.twig render
   that same wrapper as their root element so HTMX outerHTML swaps target
   a stable anchor.

   Expects:
     - detail: App\Households\Application\Query\Port\MemberDetail
#}
<div class="rounded-card border border-litrec-border bg-litrec-surface shadow-card">
    <details
        class="group"
        :open="cards.profile"
        @toggle="cards.profile = $event.target.open; syncHash()"
    >
        <summary
            class="flex cursor-pointer list-none items-center justify-between gap-2 px-5 py-3 text-sm font-semibold uppercase tracking-wide text-litrec-text-muted"
        >
            <span>Profile</span>
            <span aria-hidden="true" class="text-xs transition-transform group-open:rotate-180">▾</span>
        </summary>
        {% include 'households/detail/_card_profile_read.html.twig' with { detail: detail } only %}
    </details>
</div>
