{# Profile card — edit mode (LRA-43).

   Returned by GET  /admin/users/{h}/{m}/profile/edit and re-rendered on
   422 by POST /admin/users/{h}/{m}/profile. Replaces #card-profile-body
   in-place via outerHTML swap. On submit success the POST endpoint
   returns _card_profile_read.html.twig, swapping the card back to read
   mode with the updated values.

   Expects:
     - form: Symfony FormView bound to UpdateMemberProfileInput
     - householdId: string (UUID v7) — for the Cancel re-fetch route
     - memberId: string (UUID v7)    — for the Cancel re-fetch route
#}
<div id="card-profile-body" data-testid="card-profile-body" class="border-t border-litrec-border px-5 py-4">
    <form
        method="post"
        action="{{ path('member_profile_submit', { householdId: householdId, memberId: memberId }) }}"
        hx-post="{{ path('member_profile_submit', { householdId: householdId, memberId: memberId }) }}"
        hx-target="#card-profile-body"
        hx-swap="outerHTML"
        novalidate
    >
        {% if form.vars.errors|length > 0 %}
            <div
                role="alert"
                data-testid="profile-form-error"
                class="mb-4 rounded-md border border-danger/30 bg-danger/10 p-3 text-sm font-semibold text-danger"
            >
                {{ form_errors(form) }}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {{ form_row(form.firstName, { attr: { class: 'litrec-input' } }) }}
            {{ form_row(form.middleName, { attr: { class: 'litrec-input' } }) }}
            {{ form_row(form.lastName, { attr: { class: 'litrec-input' } }) }}
            {{ form_row(form.suffix, { attr: { class: 'litrec-input' } }) }}
            {{ form_row(form.dobIso, { attr: { class: 'litrec-input' } }) }}
            {{ form_row(form.genderCode, { attr: { class: 'litrec-input' } }) }}
        </div>

        {{ form_widget(form._token) }}

        <div class="mt-6 flex items-center justify-end gap-2">
            <button
                type="button"
                data-testid="profile-cancel"
                hx-get="{{ path('member_detail_lower_cards', { householdId: householdId, memberId: memberId }) }}"
                hx-target="#member-cards-lower"
                hx-swap="outerHTML"
                class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
            >
                Cancel
            </button>
            <button
                type="submit"
                data-testid="profile-save"
                class="rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
            >
                Save
            </button>
        </div>
    </form>
</div>
