{% extends 'base.html.twig' %}

{% block title %}Sign in — LiteRecAdmin{% endblock %}

{% block body %}
    <main id="main-content" tabindex="-1" class="flex min-h-screen items-center justify-center bg-litrec-bg p-6">
        <div
            data-gsap="card"
            class="w-full max-w-md rounded-card border border-litrec-border bg-litrec-surface p-8 shadow-card"
            x-data="{ submitting: false }"
        >
            <h1 class="text-2xl font-bold text-litrec-primary">LiteRecAdmin</h1>
            <p class="mt-1 text-sm text-litrec-text-muted">Sign in to continue.</p>

            {% if error %}
                <p role="alert" class="mt-4 text-sm font-semibold text-danger">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </p>
            {% endif %}

            <form
                method="post"
                action="{{ path('app_login') }}"
                class="mt-6 space-y-4"
                x-on:submit="submitting = true"
            >
                <div>
                    <label for="username" class="block text-sm font-medium text-litrec-text">Username</label>
                    <input
                        type="text"
                        id="username"
                        name="_username"
                        value="{{ last_username }}"
                        required
                        autofocus
                        autocomplete="username"
                        class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
                    >
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-litrec-text">Password</label>
                    <input
                        type="password"
                        id="password"
                        name="_password"
                        required
                        autocomplete="current-password"
                        class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
                    >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button
                    type="submit"
                    class="w-full rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary disabled:cursor-not-allowed disabled:opacity-60"
                    :disabled="submitting"
                    x-text="submitting ? 'Signing in…' : 'Login'"
                >Login</button>
            </form>
        </div>
    </main>
{% endblock %}
