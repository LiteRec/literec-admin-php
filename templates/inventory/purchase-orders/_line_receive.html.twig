{# Inline receive form for a single PO line. Renders a small disclosure
   that expands to a quantity input + submit; HTMX posts to the line
   receive endpoint and targets the parent #po-detail container so
   the full detail body re-renders on success.
   Expects:
     - poId: string (UUID v7)
     - line: PurchaseOrderLineDetailView #}
<div
    x-data="{ open: false }"
    class="inline-block"
>
    <button
        type="button"
        data-testid="po-line-receive-open-{{ line.lineId }}"
        x-show="!open"
        @click="open = true"
        class="rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
    >
        Receive
    </button>

    <form
        x-show="open"
        x-cloak
        hx-post="{{ path('po_line_receive', { poId: poId, lineId: line.lineId }) }}"
        hx-target="#po-detail"
        hx-swap="innerHTML"
        data-testid="po-line-receive-form-{{ line.lineId }}"
        class="inline-flex items-center gap-1"
    >
        <label class="sr-only" for="po-line-qty-{{ line.lineId }}">Quantity to receive</label>
        <input
            type="number"
            id="po-line-qty-{{ line.lineId }}"
            name="receivedQuantityUnits"
            min="1"
            max="{{ line.remainingUnits }}"
            value="{{ line.remainingUnits }}"
            class="w-20 rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-xs text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
        >
        <button
            type="submit"
            data-testid="po-line-receive-submit-{{ line.lineId }}"
            class="rounded-md bg-litrec-primary px-2 py-1 text-xs font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong"
        >
            Save
        </button>
        <button
            type="button"
            @click="open = false"
            class="rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted"
        >
            Cancel
        </button>
    </form>
</div>
