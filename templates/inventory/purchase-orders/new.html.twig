{% extends 'app.html.twig' %}

{% block page_title %}New Purchase Order{% endblock %}

{% block page_actions %}
    <a
        href="{{ path('po_index') }}"
        class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
    >
        Back to list
    </a>
{% endblock %}

{% block page_body %}
    <form
        id="purchase-order-form"
        method="post"
        action="{{ formAction }}"
        novalidate
        x-data="{
            index: {{ form.lines|length }},
            addRow() {
                var container = this.$refs.rows;
                var proto = this.$refs.proto.dataset.prototype;
                var html = proto.replace(/__name__/g, String(this.index));
                this.index = this.index + 1;
                var wrapper = document.createElement('div');
                wrapper.className = 'po-line-row mb-2 grid grid-cols-2 gap-2 sm:grid-cols-[3fr,1fr,1fr,auto] sm:items-end';
                wrapper.innerHTML = html;
                var rm = document.createElement('button');
                rm.type = 'button';
                rm.className = 'rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted';
                rm.textContent = 'Remove';
                rm.addEventListener('click', function () { wrapper.remove(); });
                wrapper.appendChild(rm);
                container.appendChild(wrapper);
            },
        }"
        class="rounded-card border border-litrec-border bg-litrec-surface p-6 shadow-card"
    >
        {% if form.vars.errors|length > 0 %}
            <div
                role="alert"
                data-testid="form-error"
                class="mb-4 rounded-md border border-danger/30 bg-danger/10 p-3 text-sm font-semibold text-danger"
            >
                {{ form_errors(form) }}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {{ form_row(form.vendorId, { attr: { class: 'litrec-input', 'data-testid': 'po-vendor-id' } }) }}
            {{ form_row(form.facilityCode, { attr: { class: 'litrec-input', 'data-testid': 'po-facility-code' } }) }}
        </div>

        <fieldset class="mt-6">
            <legend class="mb-2 text-sm font-semibold text-litrec-text">Lines</legend>

            {% if form.lines.vars.errors|length > 0 %}
                <div
                    role="alert"
                    data-testid="po-lines-error"
                    class="mb-3 rounded-md border border-danger/30 bg-danger/10 p-3 text-sm font-semibold text-danger"
                >
                    {{ form_errors(form.lines) }}
                </div>
            {% endif %}

            <span
                x-ref="proto"
                class="hidden"
                data-prototype="{{ form_widget(form.lines.vars.prototype)|e('html_attr') }}"
            ></span>

            <div x-ref="rows" data-testid="po-line-rows">
                {% for line in form.lines %}
                    <div class="po-line-row mb-2 grid grid-cols-2 gap-2 sm:grid-cols-[3fr,1fr,1fr,auto] sm:items-end">
                        {{ form_widget(line) }}
                        <button
                            type="button"
                            class="rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted"
                            @click="$el.closest('.po-line-row').remove()"
                        >
                            Remove
                        </button>
                    </div>
                {% endfor %}
            </div>

            <button
                type="button"
                data-testid="po-add-line"
                class="mt-2 rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted"
                @click="addRow()"
            >
                Add line
            </button>
        </fieldset>

        {{ form_widget(form._token) }}

        <div class="mt-6 flex items-center justify-end gap-2">
            <a
                href="{{ path('po_index') }}"
                class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
            >
                Cancel
            </a>
            <button
                type="submit"
                data-testid="po-create-submit"
                class="rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
            >
                Create Purchase Order
            </button>
        </div>
    </form>
{% endblock %}
