{# Purchase Orders table partial. Rendered both as part of the full
   list page and as the HTMX swap target when filters or pagination
   change.
   Expects:
     - page: PurchaseOrderListPage
     - query: ListPurchaseOrders #}
{% set baseQuery = app.request.query.all %}

{# Live-region OOB update so screen readers hear the new count on every
   HTMX swap. The matching id is rendered in the page shell so it
   exists on first paint. #}
<span
    id="purchase-orders-result-summary"
    hx-swap-oob="true"
    aria-live="polite"
    class="sr-only"
>Showing {{ page.items|length }} of {{ page.totalCount }} purchase orders</span>

{% if page.totalCount == 0 %}
    {% include 'components/_empty_state.html.twig' with {
        title: 'No purchase orders found',
        message: 'No purchase orders match your filters.',
        ctaLabel: 'Clear filters',
        ctaRoute: 'po_index',
    } only %}
{% else %}
    <div class="overflow-x-auto rounded-card border border-litrec-border bg-litrec-surface shadow-card">
        <table class="min-w-full divide-y divide-litrec-border text-sm">
            <thead class="bg-litrec-bg-muted text-left text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
                <tr>
                    <th scope="col" class="px-4 py-3">PO</th>
                    <th scope="col" class="px-4 py-3">Vendor</th>
                    <th scope="col" class="px-4 py-3">Facility</th>
                    <th scope="col" class="px-4 py-3">Status</th>
                    <th scope="col" class="px-4 py-3">Lines</th>
                    <th scope="col" class="px-4 py-3">Ordered</th>
                    <th scope="col" class="px-4 py-3">Received</th>
                    <th scope="col" class="px-4 py-3">Total cost</th>
                    <th scope="col" class="px-4 py-3">Created</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-litrec-border">
                {% for item in page.items %}
                    <tr
                        data-testid="po-row-{{ item.purchaseOrderId }}"
                        class="hover:bg-litrec-bg-muted"
                    >
                        <td class="whitespace-nowrap px-4 py-2 font-mono text-xs text-litrec-text">
                            <a
                                href="{{ path('po_detail', { poId: item.purchaseOrderId }) }}"
                                data-testid="po-detail-link-{{ item.purchaseOrderId }}"
                                class="font-mono text-xs text-litrec-primary hover:underline focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                            >
                                {{ item.purchaseOrderId|slice(0, 8) }}…
                            </a>
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 font-mono text-xs text-litrec-text-muted">
                            {{ item.vendorId|slice(0, 8) }}…
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">
                            {{ item.facilityCode }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2">
                            <span
                                class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-800"
                                data-testid="po-status-{{ item.purchaseOrderId }}"
                            >{{ item.status }}</span>
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">{{ item.lineCount }}</td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">{{ item.totalOrderedUnits }}</td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">{{ item.totalReceivedUnits }}</td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">
                            {{ (item.totalCostCents / 100)|number_format(2) }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                            {{ item.createdAt|date('Y-m-d') }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% set totalPages = (page.totalCount > 0) ? ((page.totalCount + page.pageSize - 1) // page.pageSize) : 1 %}
    <nav
        aria-label="Purchase orders pagination"
        class="mt-4 flex items-center justify-between text-sm text-litrec-text-muted"
    >
        <span data-testid="po-pagination-status">
            Page {{ page.pageNumber }} of {{ totalPages }}
        </span>

        <div class="flex items-center gap-2">
            {% set prevDisabled = page.pageNumber <= 1 %}
            {% set nextDisabled = page.pageNumber >= totalPages %}
            {% set prevQuery = baseQuery|merge({ page: page.pageNumber - 1 }) %}
            {% set nextQuery = baseQuery|merge({ page: page.pageNumber + 1 }) %}

            {% if prevDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >Previous</span>
            {% else %}
                <a
                    href="{{ path('po_index', prevQuery) }}"
                    hx-get="{{ path('po_table', prevQuery) }}"
                    hx-target="#purchase-orders-table"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="po-pagination-previous"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >Previous</a>
            {% endif %}

            {% if nextDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >Next</span>
            {% else %}
                <a
                    href="{{ path('po_index', nextQuery) }}"
                    hx-get="{{ path('po_table', nextQuery) }}"
                    hx-target="#purchase-orders-table"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="po-pagination-next"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >Next</a>
            {% endif %}
        </div>
    </nav>
{% endif %}
