{# Filter form for the LRA-90 Purchase Orders list page. HTMX submits any
   field change to the partial endpoint and swaps the result into
   #purchase-orders-table. #}
{% set q = app.request.query %}
<form
    hx-get="{{ path('po_table') }}"
    hx-target="#purchase-orders-table"
    hx-swap="innerHTML"
    hx-push-url="true"
    hx-trigger="input changed delay:300ms, change"
    aria-label="Filter purchase orders"
    class="rounded-card border border-litrec-border bg-litrec-surface p-4 shadow-card"
>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div>
            <label for="filter-po-vendorId" class="block text-sm font-medium text-litrec-text">Vendor ID</label>
            <input
                type="text"
                id="filter-po-vendorId"
                name="vendorId"
                value="{{ q.get('vendorId', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-po-facilityCode" class="block text-sm font-medium text-litrec-text">Facility code</label>
            <input
                type="text"
                id="filter-po-facilityCode"
                name="facilityCode"
                value="{{ q.get('facilityCode', '') }}"
                autocomplete="off"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
        </div>

        <div>
            <label for="filter-po-status" class="block text-sm font-medium text-litrec-text">Status</label>
            <select
                id="filter-po-status"
                name="status"
                class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
            >
                {% set currentStatus = q.get('status', '') %}
                <option value="" {% if currentStatus == '' %}selected{% endif %}>All statuses</option>
                {% for case in statusCases %}
                    <option value="{{ case.value }}" {% if currentStatus == case.value %}selected{% endif %}>
                        {{ case.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# Page intentionally NOT preserved across filter changes: when the
       operator narrows the result set, page 3 of the old set rarely
       maps to anything useful in the new set. Omitting the input lets
       the controller fall back to page 1. pageSize, on the other hand,
       is an operator preference and is preserved. #}
    <input type="hidden" name="pageSize" value="{{ q.get('pageSize', '') }}">

    <button type="submit" class="sr-only">Apply filters</button>
</form>
