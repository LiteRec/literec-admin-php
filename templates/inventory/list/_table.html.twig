{# Inventory table partial. Rendered both as part of the full list page
   and as the HTMX swap target when filters, sort, or pagination change.
   Expects:
     - page: InventoryListPage
     - query: ListInventory #}
{% set baseQuery = app.request.query.all %}
{% set currentSort = query.sort %}

{# Live-region OOB update so screen readers hear the new count on every
   HTMX swap. The matching id is rendered (without hx-swap-oob) in the
   page shell so it exists on first paint. #}
<span
    id="inventory-result-summary"
    hx-swap-oob="true"
    aria-live="polite"
    class="sr-only"
>Showing {{ page.items|length }} of {{ page.totalCount }} items</span>

{% if page.totalCount == 0 %}
    {% include 'components/_empty_state.html.twig' with {
        title: 'No inventory items found',
        message: 'No items match your filters.',
        ctaLabel: 'Clear filters',
        ctaRoute: 'inventory_index',
    } only %}
{% else %}
    <div class="overflow-x-auto rounded-card border border-litrec-border bg-litrec-surface shadow-card">
        <table class="min-w-full divide-y divide-litrec-border text-sm">
            <thead class="bg-litrec-bg-muted text-left text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
                <tr>
                    {# Code: sortable. Active = currentSort ends with 'code'. #}
                    {% set codeAsc  = currentSort == 'code' %}
                    {% set codeDesc = currentSort == '-code' %}
                    {% set codeNext = codeAsc ? '-code' : 'code' %}
                    <th scope="col" class="px-4 py-3">
                        <button
                            type="button"
                            hx-get="{{ path('inventory_table', baseQuery|merge({ sort: codeNext, page: 1 })) }}"
                            hx-target="#inventory-table"
                            hx-swap="innerHTML"
                            hx-push-url="true"
                            data-testid="sort-code"
                            class="inline-flex items-center gap-1 uppercase tracking-wider text-litrec-text-muted hover:text-litrec-text focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                        >
                            Code
                            {% if codeAsc %}<span aria-hidden="true">▲</span>{% endif %}
                            {% if codeDesc %}<span aria-hidden="true">▼</span>{% endif %}
                        </button>
                    </th>

                    {# Name: sortable. Default sort, so empty/default currentSort treats name asc as active. #}
                    {% set nameAsc  = currentSort == 'name' %}
                    {% set nameDesc = currentSort == '-name' %}
                    {% set nameNext = nameAsc ? '-name' : 'name' %}
                    <th scope="col" class="px-4 py-3">
                        <button
                            type="button"
                            hx-get="{{ path('inventory_table', baseQuery|merge({ sort: nameNext, page: 1 })) }}"
                            hx-target="#inventory-table"
                            hx-swap="innerHTML"
                            hx-push-url="true"
                            data-testid="sort-name"
                            class="inline-flex items-center gap-1 uppercase tracking-wider text-litrec-text-muted hover:text-litrec-text focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                        >
                            Name
                            {% if nameAsc %}<span aria-hidden="true">▲</span>{% endif %}
                            {% if nameDesc %}<span aria-hidden="true">▼</span>{% endif %}
                        </button>
                    </th>

                    <th scope="col" class="px-4 py-3">Kind</th>

                    {# Quantity: sortable. #}
                    {% set qtyAsc  = currentSort == 'quantity' %}
                    {% set qtyDesc = currentSort == '-quantity' %}
                    {% set qtyNext = qtyAsc ? '-quantity' : 'quantity' %}
                    <th scope="col" class="px-4 py-3">
                        <button
                            type="button"
                            hx-get="{{ path('inventory_table', baseQuery|merge({ sort: qtyNext, page: 1 })) }}"
                            hx-target="#inventory-table"
                            hx-swap="innerHTML"
                            hx-push-url="true"
                            data-testid="sort-quantity"
                            class="inline-flex items-center gap-1 uppercase tracking-wider text-litrec-text-muted hover:text-litrec-text focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                        >
                            Quantity on hand
                            {% if qtyAsc %}<span aria-hidden="true">▲</span>{% endif %}
                            {% if qtyDesc %}<span aria-hidden="true">▼</span>{% endif %}
                        </button>
                    </th>

                    <th scope="col" class="px-4 py-3">Reorder threshold</th>
                    <th scope="col" class="px-4 py-3">Groups</th>
                    <th scope="col" class="px-4 py-3">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-litrec-border">
                {% for item in page.items %}
                    <tr
                        data-testid="inventory-row-{{ item.inventoryItemId }}"
                        class="hover:bg-litrec-bg-muted"
                    >
                        <td class="whitespace-nowrap px-4 py-2 font-mono text-xs text-litrec-text"
                            data-testid="inventory-code-{{ item.inventoryItemId }}">
                            <button
                                type="button"
                                hx-get="{{ path('inventory_item_edit', { itemId: item.inventoryItemId }) }}"
                                hx-target="body"
                                hx-swap="beforeend"
                                aria-haspopup="dialog"
                                data-testid="edit-inventory-item-{{ item.inventoryItemId }}"
                                class="font-mono text-xs text-litrec-primary hover:underline focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                            >
                                {{ item.listingCode }}
                            </button>
                            {% if is_granted('receive_stock') %}
                                <button
                                    type="button"
                                    hx-get="{{ path('inventory_receive_form', { itemId: item.inventoryItemId }) }}"
                                    hx-target="body"
                                    hx-swap="beforeend"
                                    aria-haspopup="dialog"
                                    aria-label="Receive stock for {{ item.listingCode }}"
                                    data-testid="receive-stock-{{ item.inventoryItemId }}"
                                    class="ml-2 inline-flex items-center rounded-md border border-litrec-border bg-litrec-surface px-2 py-0.5 text-[0.65rem] font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                                >
                                    Receive
                                </button>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2 text-litrec-text">
                            {{ item.name }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                            {{ item.kind }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">
                            {{ item.totalQuantityOnHand }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                            {% if item.reorderThresholdUnits > 0 %}{{ item.reorderThresholdUnits }}{% else %}—{% endif %}
                        </td>
                        <td class="px-4 py-2 text-litrec-text-muted">
                            {% if item.groupNames is not empty %}{{ item.groupNames|join(', ') }}{% else %}—{% endif %}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2">
                            {% if item.archived %}
                                <span class="inline-flex items-center rounded-full bg-gray-200 px-2 py-0.5 text-xs font-semibold text-gray-700">Archived</span>
                            {% else %}
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800">Active</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination footer. Previous/Next reuse the current query string with
       the page param overridden, so active filters survive navigation. #}
    {% set totalPages = (page.totalCount > 0) ? ((page.totalCount + page.pageSize - 1) // page.pageSize) : 1 %}
    <nav
        aria-label="Inventory pagination"
        class="mt-4 flex items-center justify-between text-sm text-litrec-text-muted"
    >
        <span data-testid="pagination-status">
            Page {{ page.pageNumber }} of {{ totalPages }}
        </span>

        <div class="flex items-center gap-2">
            {% set prevDisabled = page.pageNumber <= 1 %}
            {% set nextDisabled = page.pageNumber >= totalPages %}
            {% set prevQuery = baseQuery|merge({ page: page.pageNumber - 1 }) %}
            {% set nextQuery = baseQuery|merge({ page: page.pageNumber + 1 }) %}

            {% if prevDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >
                    Previous
                </span>
            {% else %}
                <a
                    href="{{ path('inventory_index', prevQuery) }}"
                    hx-get="{{ path('inventory_table', prevQuery) }}"
                    hx-target="#inventory-table"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="pagination-previous"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >
                    Previous
                </a>
            {% endif %}

            {% if nextDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >
                    Next
                </span>
            {% else %}
                <a
                    href="{{ path('inventory_index', nextQuery) }}"
                    hx-get="{{ path('inventory_table', nextQuery) }}"
                    hx-target="#inventory-table"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="pagination-next"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >
                    Next
                </a>
            {% endif %}
        </div>
    </nav>
{% endif %}
