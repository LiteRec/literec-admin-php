{% extends 'app.html.twig' %}

{% block page_title %}Take Inventory{% endblock %}

{% block page_body %}
    {% if facilityCode is null %}
        {# Facility picker landing — no grid until a facility is chosen.
           The form submits a plain GET so deep-linking to a facility-
           scoped grid works (URL becomes the operator's bookmark). #}
        <div class="rounded-card border border-litrec-border bg-litrec-surface p-6 shadow-card max-w-xl">
            <h2 class="text-lg font-semibold text-litrec-text mb-4">Choose a facility</h2>
            <p class="text-sm text-litrec-text-muted mb-4">
                Pick the facility you are counting before opening the grid.
                The counted page is scoped to one facility at a time.
            </p>
            <form
                method="get"
                action="{{ path('inventory_take_index') }}"
                aria-label="Choose facility for Take Inventory"
                class="flex flex-col gap-3 sm:flex-row sm:items-end"
            >
                <div class="flex-1">
                    <label for="facility-picker" class="block text-sm font-medium text-litrec-text">Facility code</label>
                    <input
                        type="text"
                        id="facility-picker"
                        name="facilityCode"
                        required
                        autocomplete="off"
                        placeholder="e.g. MAIN"
                        class="mt-1 block w-full rounded-md border border-litrec-border bg-litrec-surface px-3 py-2 text-litrec-text focus:border-litrec-primary focus:outline-none focus:ring-1 focus:ring-litrec-primary"
                    >
                </div>
                <button
                    type="submit"
                    data-testid="take-inventory-pick-facility"
                    class="rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
                >
                    Open grid
                </button>
            </form>
        </div>
    {% else %}
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-litrec-text">
                Take Inventory — facility <span class="font-mono">{{ facilityCode }}</span>
            </h2>
            <a
                href="{{ path('inventory_take_index') }}"
                class="text-sm text-litrec-primary hover:underline"
            >Change facility</a>
        </div>

        {% include 'inventory/take/_grid.html.twig' with {
            form: form,
            facilityCode: facilityCode,
            rowErrors: rowErrors,
            topError: topError,
            maxReasonNoteLength: maxReasonNoteLength,
        } only %}
    {% endif %}
{% endblock %}
