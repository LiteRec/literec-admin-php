{# CODE128 barcode print page (LRA-86).

   Standalone page (not a fragment) — the operator opens it in a new
   tab/window from the item detail page and clicks the on-screen "Print"
   button (or uses Ctrl+P) to send it to the label printer. Print-media
   styles hide the button and shrink margins so only the barcode block
   reaches the printer.

   Expects:
     - item:        InventoryItemDetailView
     - listing:     ListingDetailView (for code + name)
     - barcodeHtml: pre-rendered HTML/SVG string from BarcodeRenderer
#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Barcode — {{ listing.code }}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            margin: 2rem;
            color: #111;
            background: #fff;
        }
        .barcode-card {
            display: inline-block;
            padding: 1rem;
            border: 1px solid #ddd;
            border-radius: 6px;
            text-align: center;
        }
        .barcode-card .code {
            margin-top: 0.5rem;
            font-family: monospace;
            font-size: 1.1rem;
            letter-spacing: 0.05em;
        }
        .barcode-card .name {
            margin-top: 0.25rem;
            font-size: 0.85rem;
            color: #555;
        }
        .no-print {
            margin-bottom: 1rem;
        }
        .no-print button {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        @media print {
            .no-print {
                display: none;
            }
            body {
                margin: 0;
                background: #fff;
            }
            .barcode-card {
                border: none;
            }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <button type="button" onclick="window.print()" data-testid="print-barcode">Print barcode</button>
    </div>

    <div class="barcode-card" data-testid="barcode-card">
        <div data-testid="barcode-render">{{ barcodeHtml|raw }}</div>
        <div class="code" data-testid="barcode-code">{{ listing.code }}</div>
        <div class="name">{{ listing.name }}</div>
    </div>
</body>
</html>
