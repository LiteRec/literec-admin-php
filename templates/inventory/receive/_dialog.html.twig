{# Receive Stock modal dialog (LRA-87). HTMX fragment returned by:
     - GET  /admin/inventory/{itemId}/receive       — render the dialog
     - POST same URL (422)                          — re-render on validation failure
     - POST same URL (409)                          — re-render on concurrent modification

   On success the POST endpoint returns 200 with `HX-Trigger: stockReceived`
   and `HX-Reswap: none`, which causes:
     1. HTMX to skip swapping (the dialog stays in the DOM untouched),
     2. The page's #inventory-table region to re-fetch itself because
        it is listening for `stockReceived from:body`,
     3. The Alpine modal listener below to call dismiss() and remove
        the dialog root.
#}
{% set body %}
    {% include 'inventory/receive/_form.html.twig' with {
        form: form,
        formAction: formAction,
        submitLabel: submitLabel,
        maxCommentLength: maxCommentLength,
    } only %}
{% endset %}

{% set modalId = 'receive-stock-modal' %}

<div
    id="{{ modalId }}-wrapper"
    @stock-received.window="$el.querySelector('.modal-root')?.remove()"
>
    {% include 'components/_modal.html.twig' with {
        id: modalId,
        title: modalTitle,
        body: body,
    } only %}
</div>

<script>
    // Bridge HTMX's HX-Trigger response header onto a window CustomEvent
    // the Alpine wrapper above is listening for. The handler is kept on
    // window.__receiveStockDialogListener so re-rendering the dialog
    // (open → 422 → re-render → close → re-open) does NOT leak more
    // copies of the listener onto document.body.
    (function () {
        if (window.__receiveStockDialogListener) {
            document.body.removeEventListener('htmx:afterOnLoad', window.__receiveStockDialogListener);
        }

        window.__receiveStockDialogListener = function (evt) {
            var xhr = evt.detail && evt.detail.xhr;
            var trigger = xhr && xhr.getResponseHeader ? xhr.getResponseHeader('HX-Trigger') : null;
            if (trigger && trigger.indexOf('stockReceived') !== -1) {
                window.dispatchEvent(new CustomEvent('stock-received'));
            }
        };

        document.body.addEventListener('htmx:afterOnLoad', window.__receiveStockDialogListener);
    })();
</script>
