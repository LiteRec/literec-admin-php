{# Item Group form partial (LRA-89). The facility-code input is shown
   only when the scope select is set to "Specific facility"; the
   controller also re-validates server-side. #}
<form
    id="inventory-item-group-form"
    method="post"
    action="{{ formAction }}"
    hx-post="{{ formAction }}"
    hx-target="closest .modal-root"
    hx-swap="outerHTML"
    novalidate
    x-data="{ scope: '{{ form.scope.vars.value|default('all') }}' }"
>
    {% include 'components/_form_error_summary.html.twig' with { form: form } only %}

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {{ form_row(form.name,     { attr: { class: 'litrec-input' } }) }}
        {{ form_row(form.colorHex, { attr: { class: 'litrec-input', type: 'color' } }) }}
    </div>

    {# Scope is fixed at creation time per the current domain contract;
       hide the controls in edit mode so the user can't enter values
       that the update path would silently drop. #}
    {% if mode == 'create' %}
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {{ form_row(form.scope, { attr: { class: 'litrec-input', 'x-model': 'scope' } }) }}
            <div x-show="scope === 'facility'" x-cloak>
                {{ form_row(form.facilityCode, { attr: { class: 'litrec-input' } }) }}
            </div>
        </div>
    {% endif %}

    {{ form_widget(form._token) }}

    <div class="mt-6 flex items-center justify-end gap-2">
        <button
            type="button"
            class="rounded-md border border-litrec-border bg-litrec-surface px-4 py-2 text-sm font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
            @click="dismiss()"
        >
            Cancel
        </button>
        <button
            type="submit"
            data-testid="inventory-item-group-submit"
            class="rounded-md bg-litrec-primary px-4 py-2 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary"
        >
            {{ submitLabel }}
        </button>
    </div>
</form>
