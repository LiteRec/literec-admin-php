{# Movements table partial for the LRA-88 history page.
   Expects:
     - page:     StockMovementPage
     - criteria: GetStockMovementHistory
     - itemId:   string (UUID v7)
   Rendered both as part of the index page and as the HTMX swap target
   when filters / pagination change. #}
{% set baseQuery = app.request.query.all %}

{# Out-of-band live region: HTMX swaps the matching id on every
   movements request so screen readers hear the new count. The
   page shell renders the initial copy without hx-swap-oob. #}
<span
    id="history-count"
    hx-swap-oob="true"
    aria-live="polite"
    class="sr-only"
>Showing {{ page.movements|length }} of {{ page.totalCount }} movements</span>

{% if page.totalCount == 0 %}
    {% include 'components/_empty_state.html.twig' with {
        title: 'No movements found',
        message: 'No stock movements match your filters.',
    } only %}
{% else %}
    <div class="overflow-x-auto rounded-card border border-litrec-border bg-litrec-surface shadow-card">
        <table class="min-w-full divide-y divide-litrec-border text-sm" data-testid="history-table">
            <thead class="bg-litrec-bg-muted text-left text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
                <tr>
                    <th scope="col" class="px-4 py-3">Date</th>
                    <th scope="col" class="px-4 py-3">Kind</th>
                    <th scope="col" class="px-4 py-3">Reason</th>
                    <th scope="col" class="px-4 py-3">Facility</th>
                    <th scope="col" class="px-4 py-3 text-right">Quantity</th>
                    <th scope="col" class="px-4 py-3">Batch</th>
                    <th scope="col" class="px-4 py-3 text-right">Cost/unit (¢)</th>
                    <th scope="col" class="px-4 py-3">Note</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-litrec-border">
                {% for movement in page.movements %}
                    {% set kindEnum = enum('App\\Inventory\\Domain\\ValueObject\\StockMovementKind').tryFrom(movement.kind) %}
                    {% set kindLabel = kindEnum is not null ? kindEnum.label : movement.kind %}
                    {% set isOutbound = kindEnum is not null and kindEnum.isOutbound() %}
                    {% set signedQty = isOutbound ? '-' ~ movement.quantity : movement.quantity %}
                    <tr
                        data-testid="history-row-{{ movement.movementId }}"
                        class="hover:bg-litrec-bg-muted"
                    >
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">
                            {{ movement.recordedAt|date('Y-m-d H:i') }}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2">
                            <span class="inline-flex items-center rounded-full bg-litrec-bg-muted px-2 py-0.5 text-xs font-semibold text-litrec-text">{{ kindLabel }}</span>
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text-muted">{{ movement.reason }}</td>
                        <td class="whitespace-nowrap px-4 py-2 text-litrec-text">{{ movement.facilityCode }}</td>
                        <td class="whitespace-nowrap px-4 py-2 text-right font-mono text-litrec-text">{{ signedQty }}</td>
                        <td class="whitespace-nowrap px-4 py-2 font-mono text-xs text-litrec-text-muted">
                            {% if movement.stockBatchId %}{{ movement.stockBatchId|slice(0, 8) }}{% else %}—{% endif %}
                        </td>
                        <td class="whitespace-nowrap px-4 py-2 text-right font-mono text-litrec-text-muted">{{ movement.costPerUnitCents }}</td>
                        <td class="px-4 py-2 text-litrec-text-muted">{{ movement.operatorNote|default('—') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% set totalPages = (page.totalCount > 0) ? ((page.totalCount + page.pageSize - 1) // page.pageSize) : 1 %}
    <nav
        aria-label="Movement history pagination"
        class="mt-4 flex items-center justify-between text-sm text-litrec-text-muted"
    >
        <span data-testid="history-pagination-status">
            Page {{ page.pageNumber }} of {{ totalPages }}
        </span>

        <div class="flex items-center gap-2">
            {% set prevDisabled = page.pageNumber <= 1 %}
            {% set nextDisabled = page.pageNumber >= totalPages %}
            {% set prevQuery = baseQuery|merge({ page: page.pageNumber - 1 }) %}
            {% set nextQuery = baseQuery|merge({ page: page.pageNumber + 1 }) %}

            {% if prevDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >
                    Previous
                </span>
            {% else %}
                <a
                    href="{{ path('inventory_item_history', prevQuery|merge({ itemId: itemId })) }}"
                    hx-get="{{ path('inventory_item_history_movements', prevQuery|merge({ itemId: itemId })) }}"
                    hx-target="#movements"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="history-pagination-previous"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >
                    Previous
                </a>
            {% endif %}

            {% if nextDisabled %}
                <span
                    aria-disabled="true"
                    class="cursor-not-allowed rounded-md border border-litrec-border bg-litrec-bg-muted px-3 py-1 text-xs font-semibold text-litrec-text-muted opacity-60"
                >
                    Next
                </span>
            {% else %}
                <a
                    href="{{ path('inventory_item_history', nextQuery|merge({ itemId: itemId })) }}"
                    hx-get="{{ path('inventory_item_history_movements', nextQuery|merge({ itemId: itemId })) }}"
                    hx-target="#movements"
                    hx-swap="innerHTML"
                    hx-push-url="true"
                    data-testid="history-pagination-next"
                    class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
                >
                    Next
                </a>
            {% endif %}
        </div>
    </nav>
{% endif %}
