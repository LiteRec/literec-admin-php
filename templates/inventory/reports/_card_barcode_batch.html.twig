{# Barcode Batch Print report card (LRA-91). Stub tile — clicking
   the launch button opens the dedicated picker page, which uses the
   reusable Alpine-driven multi-select form. #}
<section
    aria-labelledby="barcode-batch-heading"
    data-testid="report-card-barcode-batch"
    class="rounded-card border border-litrec-border bg-litrec-surface p-4 shadow-card"
>
    <header class="flex items-center justify-between gap-2">
        <h2 id="barcode-batch-heading" class="text-lg font-semibold text-litrec-text">Barcode Batch Print</h2>
        <a
            href="{{ path('inventory_reports_barcode_form') }}"
            data-testid="report-barcode-batch-launch"
            class="rounded-md bg-litrec-primary px-3 py-1 text-xs font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-litrec-primary"
        >
            Launch picker
        </a>
    </header>
    <p class="mt-3 text-sm text-litrec-text-muted">
        Select multiple inventory items and print a sheet of CODE128 barcode labels.
    </p>
</section>
