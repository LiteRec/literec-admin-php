{# Low Stock Alerts report card shell (LRA-91).
   Expects:
     - lowStock: list<LowStockAlertView>
     - criteria: GetLowStockAlerts|null #}
<section
    aria-labelledby="low-stock-heading"
    data-testid="report-card-low-stock"
    class="rounded-card border border-litrec-border bg-litrec-surface p-4 shadow-card"
>
    <header class="flex items-center justify-between gap-2">
        <h2 id="low-stock-heading" class="text-lg font-semibold text-litrec-text">Low Stock Alerts</h2>
        <a
            href="{{ path('inventory_reports_low_stock_export', app.request.query.all) }}"
            data-testid="report-low-stock-export"
            class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
        >
            Export CSV
        </a>
    </header>

    <form
        class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2"
        hx-get="{{ path('inventory_reports_low_stock_card') }}"
        hx-target="#low-stock-body"
        hx-swap="innerHTML"
        hx-trigger="submit, change delay:200ms from:input"
    >
        {% set facilityValue = criteria is not null ? (criteria.facilityCode ?? '') : '' %}
        <label class="text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
            <span class="sr-only">Facility</span>
            <input
                type="text"
                name="facilityCode"
                placeholder="Facility code (blank for all)"
                value="{{ facilityValue }}"
                data-testid="report-low-stock-facility"
                class="mt-1 w-full rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm text-litrec-text"
            />
        </label>
    </form>

    <div id="low-stock-body" class="mt-4">
        {% include 'inventory/reports/_card_low_stock_body.html.twig' with {
            lowStock: lowStock,
        } only %}
    </div>
</section>
