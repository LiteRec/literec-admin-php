{# Barcode batch print sheet (LRA-91).
   Standalone HTML page — operator opens it from the picker form, then
   uses Ctrl+P (or the on-screen button) to send to a label printer.
   Layout targets a US Letter sheet with a 3-column label grid that
   prints crisply on Avery-style sheets.

   Expects:
     - labels: list<{
         inventoryItemId: string,
         listingCode:     string,
         name:            string,
         barcodeHtml:     string,  (pre-rendered HTML/SVG, trusted)
       }>
#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Barcode batch — {{ labels|length }} label{{ labels|length == 1 ? '' : 's' }}</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            margin: 0;
            background: #fff;
            color: #111;
        }
        .toolbar {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #ddd;
            background: #f7f7f7;
        }
        .toolbar button {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        @page { size: letter; margin: 0.5in; }
        @media print {
            .no-print { display: none; }
            body { background: white; }
        }
        /*
         * US Letter print area is 8.5in - (2 * 0.5in @page margin) =
         * 7.5in wide. Three columns at 2.5in each fit exactly without
         * overflow. Extra grid padding was removed because @page
         * already provides the page-edge margin.
         */
        .label-grid {
            display: grid;
            grid-template-columns: repeat(3, 2.5in);
            grid-auto-rows: 1in;
            gap: 0;
        }
        .label {
            padding: 0.1in;
            text-align: center;
            overflow: hidden;
            border: 1px dashed transparent;
        }
        .label .code {
            font-family: monospace;
            font-size: 0.85rem;
            margin-top: 0.05in;
        }
        .label .name {
            font-size: 0.7rem;
            color: #555;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="toolbar no-print">
        <button type="button" onclick="window.print()" data-testid="report-barcode-print-button">
            Print {{ labels|length }} label{{ labels|length == 1 ? '' : 's' }}
        </button>
    </div>

    {% if labels|length == 0 %}
        <p style="padding: 2rem; text-align: center;" data-testid="report-barcode-empty">
            No items selected — return to the picker and select at least one item.
        </p>
    {% else %}
        <div class="label-grid" data-testid="report-barcode-label-grid">
            {% for label in labels %}
                <div class="label" data-testid="report-barcode-label-{{ label.inventoryItemId }}">
                    <div>{{ label.barcodeHtml|raw }}</div>
                    <div class="code">{{ label.listingCode }}</div>
                    <div class="name">{{ label.name }}</div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</body>
</html>
