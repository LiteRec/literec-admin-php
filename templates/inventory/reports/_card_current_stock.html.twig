{# Current Stock report card shell (LRA-91).
   Expects:
     - currentStock: CurrentStockReportPage
     - criteria:     CurrentStockReport|null

   The card body (the table + count) lives in
   `_card_current_stock_body.html.twig` so the HTMX swap target only
   re-renders the body, not the surrounding form. #}
<section
    role="region"
    aria-labelledby="current-stock-heading"
    data-testid="report-card-current-stock"
    class="rounded-card border border-litrec-border bg-litrec-surface p-4 shadow-card"
>
    <header class="flex items-center justify-between gap-2">
        <h2 id="current-stock-heading" class="text-lg font-semibold text-litrec-text">Current Stock</h2>
        <a
            href="{{ path('inventory_reports_current_stock_export', app.request.query.all) }}"
            data-testid="report-current-stock-export"
            class="rounded-md border border-litrec-border bg-litrec-surface px-3 py-1 text-xs font-semibold text-litrec-text hover:bg-litrec-bg-muted focus:outline-none focus:ring-2 focus:ring-litrec-primary"
        >
            Export CSV
        </a>
    </header>

    <form
        class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3"
        hx-get="{{ path('inventory_reports_current_stock_card') }}"
        hx-target="#current-stock-body"
        hx-swap="innerHTML"
        hx-trigger="submit, change delay:200ms from:input"
    >
        {% set facilityValue = criteria is not null ? (criteria.facilityCode ?? '') : '' %}
        {% set kindValue     = criteria is not null ? (criteria.kindFilter ?? '') : '' %}
        {% set groupValue    = criteria is not null ? (criteria.groupId ?? '') : '' %}
        <label class="text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
            <span class="sr-only">Facility</span>
            <input
                type="text"
                name="facilityCode"
                placeholder="Facility code"
                value="{{ facilityValue }}"
                data-testid="report-current-stock-facility"
                class="mt-1 w-full rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm text-litrec-text"
            />
        </label>
        <label class="text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
            <span class="sr-only">Kind</span>
            <input
                type="text"
                name="kind"
                placeholder="Kind"
                value="{{ kindValue }}"
                data-testid="report-current-stock-kind"
                class="mt-1 w-full rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm text-litrec-text"
            />
        </label>
        <label class="text-xs font-semibold uppercase tracking-wider text-litrec-text-muted">
            <span class="sr-only">Group</span>
            <input
                type="text"
                name="groupId"
                placeholder="Group ID"
                value="{{ groupValue }}"
                data-testid="report-current-stock-group"
                class="mt-1 w-full rounded-md border border-litrec-border bg-litrec-surface px-2 py-1 text-sm text-litrec-text"
            />
        </label>
    </form>

    <div id="current-stock-body" class="mt-4">
        {% include 'inventory/reports/_card_current_stock_body.html.twig' with {
            currentStock: currentStock,
        } only %}
    </div>
</section>
