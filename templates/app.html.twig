{% extends 'base.html.twig' %}

{% block title %}{{ block('page_title') }} — LiteRecAdmin{% endblock %}

{% block body %}
    {% import 'components/_icon.html.twig' as icon %}
    <div class="lr-screen flex min-h-screen flex-col">
        {# Shared polite live region (LRA-153). HTMX success responses emit
           HX-Trigger events that bubble to the body; assets/app.js writes a
           short status message here so screen readers hear the outcome of an
           in-place update (a save, a purchase-order transition, a member
           switch) without any focus change. #}
        <div id="lr-live" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

        <header class="lr-header">
            <div class="lr-header-in">
                <a href="{{ path('app_dashboard') }}" class="lr-brand" aria-label="LiteRecAdmin home">
                    <span class="lr-brand-mark">{{ icon.icon('leaf', 18) }}</span>
                    <span class="lr-brand-name">LiteRecAdmin</span>
                </a>

                <div class="lr-header-right">
                    <span data-testid="selected-facility" class="lr-facility-pill">
                        {{ icon.icon('pin', 13) }}
                        <span class="sr-only">Selected facility: </span>{{ selected_facility() }}
                    </span>

                    {# Light/dark theme toggle (LRA-123). `dark` is seeded from the
                       data-theme attribute the base.html.twig bootstrap script set
                       before paint; clicking flips the attribute and persists it. #}
                    <button
                        type="button"
                        class="lr-iconbtn"
                        data-testid="theme-toggle"
                        x-data="{ dark: document.documentElement.getAttribute('data-theme') === 'dark' }"
                        @click="dark = !dark;
                                document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
                                try { localStorage.setItem('lr-theme', dark ? 'dark' : 'light'); } catch (e) {}"
                        :aria-pressed="dark ? 'true' : 'false'"
                        aria-label="Toggle dark theme"
                    >
                        <span x-show="!dark">{{ icon.icon('moon', 17) }}</span>
                        <span x-show="dark" x-cloak>{{ icon.icon('sun', 17) }}</span>
                    </button>

                    {% if app.user %}
                        <div
                            class="relative"
                            x-data="{ open: false }"
                            @keydown.escape.window="open = false"
                            @click.outside="open = false"
                        >
                            <button
                                type="button"
                                class="lr-avatar"
                                @click="open = !open"
                                aria-haspopup="true"
                                :aria-expanded="open ? 'true' : 'false'"
                                aria-label="Account menu for {{ app.user.username }}"
                            ><span aria-hidden="true">{{ app.user.username|user_initials }}</span></button>

                            <div
                                x-show="open"
                                x-cloak
                                x-trap.noscroll="open"
                                role="menu"
                                aria-label="Account menu"
                                class="absolute right-0 top-full z-10 mt-2 min-w-[12rem] rounded-card border border-litrec-border bg-litrec-surface py-1 shadow-pop"
                            >
                                <p class="px-4 py-2 text-xs">
                                    <span class="sr-only">Signed in as </span>
                                    <span aria-hidden="true" class="lr-muted">Signed in as</span>
                                    <strong class="block text-litrec-text">{{ app.user.username }}</strong>
                                </p>
                                <form method="post" action="{{ path('app_logout') }}" class="border-t border-litrec-border px-2 pt-1">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" role="menuitem" aria-label="Sign out of your account" class="lr-btn lr-btn-ghost lr-btn-block">
                                        Sign out
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </header>

        {% include 'components/_main_nav.html.twig' %}

        <main id="main-content" tabindex="-1" class="mx-auto w-full max-w-7xl flex-1 px-6 py-8">
            {# Breadcrumbs slot: pages fill it by including _breadcrumbs with a
               trail array (a block can't carry an array, so the include lives in
               the page, not here). Renders nothing when a page provides none. #}
            {% block breadcrumbs %}{% endblock %}

            {# Define-and-capture pattern: declare the blocks so children can
               override them, then forward them as parameters to the
               _page_header component. The header markup itself lives in
               the component, not here. #}
            {% set page_title_text %}{% block page_title %}{% endblock %}{% endset %}
            {% set page_subtitle_text %}{% block page_subtitle %}{% endblock %}{% endset %}
            {% set page_actions_html %}{% block page_actions %}{% endblock %}{% endset %}

            {% include 'components/_page_header.html.twig' with {
                title: page_title_text,
                subtitle: page_subtitle_text,
                actions: page_actions_html,
            } only %}

            {% block page_body %}{% endblock %}
        </main>

        <footer class="border-t border-litrec-border bg-litrec-surface">
            <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-3 text-xs text-litrec-text-muted">
                <span>© {{ 'now'|date('Y') }} LiteRec</span>
                <span>build {{ build_version() }}</span>
            </div>
        </footer>
    </div>
{% endblock %}
