{% extends 'base.html.twig' %}

{% block title %}{{ block('page_title') }} — LiteRecAdmin{% endblock %}

{% block body %}
    <div class="flex min-h-screen flex-col bg-litrec-bg text-litrec-text">
        <header class="border-b border-litrec-border bg-litrec-surface">
            <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-3">
                <a href="{{ path('app_dashboard') }}" class="text-lg font-bold text-litrec-primary">LiteRecAdmin</a>

                <div class="flex items-center gap-3 text-sm text-litrec-text-muted sm:gap-6">
                    <span data-testid="selected-facility" class="hidden md:block">
                        <span class="sr-only">Selected facility: </span>{{ selected_facility() }}
                    </span>
                    {% if app.user %}
                        <span class="hidden max-w-[10rem] truncate md:block">
                            <span class="sr-only">Signed in as </span>
                            <span aria-hidden="true">Signed in as </span>
                            <strong class="text-litrec-text">{{ app.user.username }}</strong>
                        </span>
                        <form method="post" action="{{ path('app_logout') }}" class="shrink-0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button type="submit" aria-label="Sign out of your account" class="whitespace-nowrap rounded-md bg-litrec-primary px-3 py-1.5 text-sm font-semibold text-litrec-on-primary shadow-sm hover:bg-litrec-primary-strong focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-litrec-primary">
                                Sign out
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </header>

        {% include 'components/_main_nav.html.twig' %}

        <main class="mx-auto w-full max-w-7xl flex-1 px-6 py-8">
            {# Define-and-capture pattern: declare the blocks so children can
               override them, then forward them as parameters to the
               _page_header component. The header markup itself lives in
               the component, not here. #}
            {% set page_title_text %}{% block page_title %}{% endblock %}{% endset %}
            {% set page_actions_html %}{% block page_actions %}{% endblock %}{% endset %}

            {% include 'components/_page_header.html.twig' with {
                title: page_title_text,
                actions: page_actions_html,
            } only %}

            {% block page_body %}{% endblock %}
        </main>

        <footer class="border-t border-litrec-border bg-litrec-surface">
            <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-3 text-xs text-litrec-text-muted">
                <span>© {{ 'now'|date('Y') }} LiteRec</span>
                <span>build {{ build_version() }}</span>
            </div>
        </footer>
    </div>
{% endblock %}
