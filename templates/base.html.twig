<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="csrf-token" content="{{ csrf_token('htmx') }}">
        {# Theme bootstrap (LRA-123): set data-theme before first paint so there
           is no flash of the wrong theme. Reads the stored choice, else the OS
           preference. Must stay inline and synchronous — an Alpine init runs
           too late. #}
        <script>
            (function () {
                try {
                    var stored = localStorage.getItem('lr-theme');
                    var theme = (stored === 'light' || stored === 'dark')
                        ? stored
                        : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    document.documentElement.setAttribute('data-theme', theme);
                } catch (e) { /* storage blocked — fall back to the light default */ }
            })();
        </script>
        <title>{% block title %}LiteRecAdmin{% endblock %}</title>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# Skip link (LRA-156, WCAG 2.4.1): the first focusable element on every
           page so keyboard users can bypass the repeated header and nav. Hidden
           until focused; targets the page's <main id="main-content">. #}
        <a
            href="#main-content"
            class="sr-only rounded-md focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-litrec-surface focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-litrec-text focus:shadow-card focus:outline focus:outline-2 focus:outline-transparent focus:ring-2 focus:ring-litrec-primary"
        >Skip to main content</a>
        {% block body %}{% endblock %}
    </body>
</html>
