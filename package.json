{
  "name": "literec-admin-php-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end QA suite for LiteRecAdmin (LRA-161).",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:db": "composer db:reset-test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.18.0",
    "typescript": "^6.0.3"
  }
}
