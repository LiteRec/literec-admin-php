{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.7",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "picqer/php-barcode-generator": "^3.2.4",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/clock": "8.1.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/flex": "^2.10",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.1.*",
        "symfony/intl": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/mime": "8.1.*",
        "symfony/monolog-bundle": "^3.0|^4.0.2",
        "symfony/notifier": "8.1.*",
        "symfony/process": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.1.*",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/web-link": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/tailwind-bundle": "^0.13.0",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/twig": "^2.12|^3.27"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true,
        "platform": {
            "php": "8.5.5"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "stan": [
            "@php bin/console cache:warmup --quiet",
            "phpstan analyse --memory-limit=512M"
        ],
        "deptrac": "vendor/bin/deptrac analyse --no-progress",
        "test": [
            "@php bin/console tailwind:build",
            "phpunit --testsuite=all"
        ],
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:functional": [
            "@php bin/console tailwind:build",
            "phpunit --testsuite=functional"
        ],
        "test:slow": [
            "@php bin/console tailwind:build",
            "phpunit --testsuite=all --group=slow"
        ],
        "db:reset": [
            "@php bin/console doctrine:database:drop --if-exists --force --env=dev",
            "@php bin/console doctrine:database:create --env=dev",
            "@php bin/console doctrine:migrations:migrate -n --env=dev",
            "@php bin/console doctrine:fixtures:load -n --group=dev --env=dev"
        ],
        "db:reset-test": [
            "@php bin/console doctrine:database:drop --if-exists --force --env=test",
            "@php bin/console doctrine:database:create --env=test",
            "@php bin/console doctrine:migrations:migrate -n --env=test",
            "@php bin/console doctrine:fixtures:load -n --group=test --env=test"
        ],
        "fixtures:dev": "@php bin/console doctrine:fixtures:load -n --group=dev --env=dev",
        "fixtures:test": "@php bin/console doctrine:fixtures:load -n --group=test --env=test",
        "qa": [
            "@cs",
            "@stan",
            "@deptrac",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "cs": "Check coding standards with PHP_CodeSniffer (PSR-12)",
        "cs-fix": "Auto-fix coding standard violations with phpcbf",
        "stan": "Run static analysis with PHPStan (level 9)",
        "deptrac": "Enforce DDD/Hex layer dependencies with Deptrac",
        "test": "Build Tailwind, then run the full PHPUnit suite (Unit + Integration + Functional)",
        "test:unit": "Run the Unit testsuite only — must finish under 10 seconds",
        "test:integration": "Run the Integration testsuite (KernelTestCase + Postgres)",
        "test:functional": "Build Tailwind, then run the Functional testsuite (WebTestCase + Postgres)",
        "test:slow": "Build Tailwind, then run only the tests in the slow group",
        "db:reset": "Drop, recreate, migrate, and reseed the dev database from fixtures (group dev)",
        "db:reset-test": "Drop, recreate, migrate, and reseed the test database from fixtures (group test)",
        "fixtures:dev": "Load fixtures (group dev) into the dev database (no drop/migrate)",
        "fixtures:test": "Load fixtures (group test) into the test database (no drop/migrate)",
        "qa": "Run all quality gates: coding standards, static analysis, architecture and tests"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*",
            "docker": true
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "deptrac/deptrac": "^4.6.1",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "fakerphp/faker": "^1.24.1",
        "phpstan/phpstan": "^2.1.56",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "phpstan/phpstan-symfony": "^2.0.18",
        "phpunit/phpunit": "^13.1.13",
        "squizlabs/php_codesniffer": "^4.0.1",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*"
    }
}
